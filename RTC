#include "rtc_manager.h"
#include <Wire.h>
#include <RTClib.h>

RTC_DS3231 rtc;

bool initRTC() {
    Wire.begin(21, 22);  // SDA, SCL
    if (!rtc.begin()) {
        Serial.println("RTC ERROR");
        return false;
    }
    
    if (rtc.lostPower()) {
        rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
    }
    return true;
}

DateTime getCurrentTime() {
    return rtc.now();
}
